{
  "version": 2,
  "builds": [
    { "src": "*.html", "use": "@vercel/static" },
    { "src": "*.gif",  "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/",             "dest": "/home.html" },
    { "src": "/vicente",      "dest": "/vicente.html" },
    { "src": "/(.*)",         "dest": "/$1" }
  ]
}
